Imports: {
	import java.lang.*;
	import java.io.*;
	import java.util.regex.*;
	import uk.ac.rothamsted.ide.gbcl.*;
	import java.net.*;
}

Phase:CooccurrenceMatcher
Input: Token

Options: control = once

Rule:extract
(
	{Token}

):ground

-->
{
